# Defaults for local dev. For real secrets use a `.env` file (gitignored); it overrides this file.
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=deepseek-v4-flash
# Optional: OpenAI-compatible endpoint (omit for https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.deepseek.com
APP_NAME=LangChain Multi Agent Demo
LOG_LEVEL=INFO
